        </div>

        <div class="field">
          <label>Движение</label>
          <input type="text"  name="commentMoves">
        </div>

        <div class="field">
          <label>Пведение & темперамент</label>
          <input type="text"  name="commentBehave">
        </div>


        <div class="radio-row">
          <span class="label-text">1. Проверка реакции при шуме</span>
          <div class="radio-group">
              <label><input type="radio" name="noiseReaction" value="aaa">без проблем</label>
              <label><input type="radio" name="noiseReaction" value="bbb">сдержан, слегка насторожен</label>
              <label><input type="radio" name="noiseReaction" value="ccc">держится неуверенно</label>
              <label><input type="radio" name="noiseReaction" value="ddd">очень испуган</label>
          </div>
        </div>

        <div class="radio-row">
          <span class="label-text">2. Проверка на столе</span>
          <div class="radio-group">
              <label><input type="radio" name="noise2" value="eee">ведет себя дружелюбно</label>
              <label><input type="radio" name="noise2" value="fff">сдержан</label>
              <label><input type="radio" name="noise2" value="ggg">держится неуверенно</label>
              <label><input type="radio" name="noise2" value="hhh">очень испуган</label>
              <label><input type="radio" name="noise2" value="iii">проявляет агрессию</label>
          </div>
        </div>
        
        <div class="radio-row">
          <span class="label-text">3. Проверка при осмотре зубов </span>
          <span><input type="radio" name="teethObsv10" value="jjj">зубы осматривает судья</span>
          <div class="radio-group">
              <label><input type="radio" name="teethObsv1" value="kkk">без проблем</label>
              <label><input type="radio" name="teethObsv1" value="lll">с трудом</label>
              <label><input type="radio" name="teethObsv1" value="mmm">проявляет страх</label>
              <label><input type="radio" name="teethObsv1" value="nnn">невозможно осмотреть</label>
              <label><input type="radio" name="teethObsv1" value="ooo">не пытался</label>
          </div>
          <span><input type="radio" name="teethObsv20" value="ppp">зубы осматривает ведущий собак</span>
          <div class="radio-group">
              <label><input type="radio" name="teethObsv2" value="qqq">без проблем</label>
              <label><input type="radio" name="teethObsv2" value="rrr">с трудом</label>
              <label><input type="radio" name="teethObsv2" value="sss">проявляет страх</label>
              <label><input type="radio" name="teethObsv2" value="ttt">невозможно осмотреть</label>
              <label><input type="radio" name="teethObsv2" value="uuu">не пытался</label>
          </div>
        </div>

        <div class="radio-row">
          <span class="label-text">4. Проверка при показе</span>
          <div class="radio-group">
              <label><input type="radio" name="showtime" value="vvv">уверен в себе</label>
              <label><input type="radio" name="showtime" value="www">дружелюбен</label>
              <label><input type="radio" name="showtime" value="xxx">сдержан</label>
              <label><input type="radio" name="showtime" value="yyy">держится неуверенно</label>
              <label><input type="radio" name="showtime" value="zzz">проявляет агрессию</label>
          </div>
        </div>

        <div class="field">
