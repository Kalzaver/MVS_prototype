<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>Другая страница</title>
  <link rel="stylesheet" type="text/css" href="public/css/style.css">
</head>
<body>
   <% tfetch(QString, newTitle); %>
   <h1><%= newTitle %></h1>
   <div class="reportContainer grid-form">
      <%== formTag(urla("submitForm"), Tf::Post) %>

      <div class="field">
        <label>Полное название клуба</label>
        <input type="text"    name="NamePutOfTheClubHere">
      </div>

      <div class="field">
        <label>Порода</label>
        <input type="text"  name="NameOfTheBreed">
      </div>

      <div class="field">
        <label>Кличка собаки</label>
        <input type="text"  name="NameOfTheDog">
      </div>

      <div class="field">
        <label>Номер регистрации в РКФ</label>
        <input type="text"  name="NumberFromRKFBase">
      </div>

      <div class="field">
        <label>НКлеймо (микрочип)</label>
        <input type="text"  name="PuthTheChipHere">
      </div>

      <div class="field">
        <label>Отец</label>
        <input type="text"  name="HereIsYourFather">
      </div>

      <div class="field">
        <label>Мать</label>
        <input type="text"  name="HereIsYourMother">
      </div>

      <div class="field">
        <label>Заводчик</label>
        <input type="text"  name="hoIsTheBreeder">
      </div>

      <div class="field">
        <label>Владелец</label>
        <input type="text"  name="WhoIsTheOwner">
      </div>

      <div class="field">
        <label>Адрес владельца</label>
        <input type="text"  name="PutYourCurrentAdress">
      </div>

      <div class="photo"> <img src="/images/dogsbody.jpg" alt="анатомия и стати собаки"> </div>

      <div class="field">
        <label>Вес собаки</label>
        <input type="text"    name="PutWeightHere">
      </div>

      <div class="field">
        <label>Высота в холке</label>
        <input type="text"  name="PutHieghtHere">
      </div>

      <div class="field">
        <label>Косая длина туловиша</label>
        <input type="text"  name="PutHere">
      </div>

      <div class="field">
        <label>Высота в локте</label>
        <input type="text"  name="PutElbowHere">
      </div>

      <div class="field">
        <label>Глубина в груди</label>
        <input type="text"  name="PutDepthHere">
      </div>

      <div class="field">
        <label>Обхват груди</label>
        <input type="text"  name="PutChestHere">
      </div>

      <div class="field">
        <label>Обхват пясти</label>
        <input type="text"  name="PutCircimferenceHere">
      </div>

      <div class="field">
        <label>Длина головы</label>
        <input type="text"  name="PutHeadLengthHere">
      </div>

      <div class="field">
        <label>Длина морды</label>
        <input type="text"  name="PutMuzzleHere">
      </div>

      <div class="field">
        <label>Обхват черепа перед ушами</label>
        <input type="text"  name="PutSkullHere">
      </div>

      <div class="field">
        <label>Обхват морды у основания</label>
        <input type="text"  name="PutfoundingHere">
      </div>

      <div class="field">
        <label>Общий вид и тип</label>
        <input type="text"  name="SomeKindOfComments1">
      </div>

      <div class="field">
        <label>Половой диморфизм</label>
        <input type="text"  name="SomeKindOfComments2">
      </div>

      <div class="field">
        <label>Голова</label>
        <input type="text"  name="SomeKindOfComments3">
      </div>

      <div class="field">
        <label>Глаза, выражение</label>
        <input type="text"  name="SomeKindOfComments4">
      </div>

      <div class="field">
        <label>Уши</label>
        <input type="text"  name="SomeKindOfComments5">
      </div>

      <div class="field">
        <label>Зубы</label>
        <input type="text"  name="SomeKindOfComments6">
      </div>

      <div class="photo"> <img src="/images/jaws.jpg" alt="анатомия и стати собаки"> </div>

        <div class="radio-row">
          <span class="label-text">Оценка прикуса: Ножницеобразный</span>
          <div class="radio-group">
            <label><input type="radio" name="bite_scissor" value="yes"> Да</label>
            <label><input type="radio" name="bite_scissor" value="no"> Нет</label>
          </div>
        </div>


        <div class="radio-row">
          <span class="label-text">Прямой</span>
          <div class="radio-group">
            <label><input type="radio" name="bite_direct" value="yes"> Да</label>
            <label><input type="radio" name="bite_direct" value="no"> Нет</label>
          </div>
        </div>


        <div class="radio-row">
          <span class="label-text">Частично прямой</span>
          <div class="radio-group">
            <label><input type="radio" name="bite_straight" value="yes"> Да</label>
            <label><input type="radio" name="bite_straight" value="no"> Нет</label>
          </div>
        </div>

        <div class="radio-row">
          <span class="label-text">Перекус (отход в мм)</span>
          <div class="radio-group">
            <label><input type="radio" name="bite_toomuch" value="yes"> Да</label>
            <label><input type="radio" name="bite_toomuch" value="no"> Нет</label>
          </div>
        </div>

        <div class="radio-row">
          <span class="label-text">Недокус</span>
          <div class="radio-group">
            <label><input type="radio" name="bite_less" value="yes"> Да</label>
            <label><input type="radio" name="bite_less" value="no"> Нет</label>
          </div>
        </div>

        <div class="radio-row">
          <span class="label-text">Перекрёстный</span>
          <div class="radio-group">
            <label><input type="radio" name="bite_crossed" value="yes"> Да</label>
            <label><input type="radio" name="bite_crossed" value="no"> Нет</label>
          </div>
        </div>

        <div class="radio-row">
          <span class="label-text">Нерядность</span>
          <div class="radio-group">
            <label><input type="radio" name="bite_onrow" value="yes"> Да</label>
            <label><input type="radio" name="bite_onrow" value="no"> Нет</label>
          </div>
        </div>

        <div class="radio-row">
          <span class="label-text">Неправильное положение нижних клыков</span>
          <div class="radio-group">
            <label><input type="radio" name="bite_meat" value="yes"> Да</label>
            <label><input type="radio" name="bite_meat" value="no"> Нет</label>
          </div>
        </div>

        <div class="field">
          <label>Примечание</label>
          <input type="text"  name="HereYourNotes">
        </div>

        <div class="field">
          <label>Шея</label>
          <input type="text"  name="commentNeck">
        </div>

        <div class="field">
          <label>Холка, спина и поясница</label>
          <input type="text"  name="commentBack">
        </div>

        <div class="field">
          <label>Круп</label>
          <input type="text"  name="commentCroup">
        </div>

        <div class="field">
          <label>Хвост (постав) и состояние</label>
          <input type="text"  name="commentTail">
        </div>

        <div class="field">
          <label>Грудная клетка</label>
          <input type="text"  name="commentChect">
        </div>

        <div class="field">
          <label>Плечи и локти. Углы передних конечностей</label>
          <input type="text"  name="commentShoulders">
        </div>

        <div class="field">
          <label>Углы задних конечностей</label>
          <input type="text"  name="commentAngu">
        </div>

        <div class="field">
          <label>Шерсть (тип и структура)</label>
          <input type="text"  name="commentFurr">
        </div>

        <div class="field">
          <label>Окрас и пигментация</label>
          <input type="text"  name="commentColor">
        </div>

        <div class="field">
          <label>Движение</label>
          <input type="text"  name="commentMoves">
        </div>

        <div class="field">
          <label>Пведение & темперамент</label>
          <input type="text"  name="commentBehave">
        </div>


        <div class="radio-row">
          <span class="label-text">1. Проверка реакции при шуме</span>
          <div class="radio-group">
              <label><input type="radio" name="noiseReaction" value="aaa">без проблем</label>
              <label><input type="radio" name="noiseReaction" value="bbb">сдержан, слегка насторожен</label>
              <label><input type="radio" name="noiseReaction" value="ccc">держится неуверенно</label>
              <label><input type="radio" name="noiseReaction" value="ddd">очень испуган</label>
          </div>
        </div>

        <div class="radio-row">
          <span class="label-text">2. Проверка на столе</span>
          <div class="radio-group">
              <label><input type="radio" name="noise2" value="eee">ведет себя дружелюбно</label>
              <label><input type="radio" name="noise2" value="fff">сдержан</label>
              <label><input type="radio" name="noise2" value="ggg">держится неуверенно</label>
              <label><input type="radio" name="noise2" value="hhh">очень испуган</label>
              <label><input type="radio" name="noise2" value="iii">проявляет агрессию</label>
          </div>
        </div>
        
        <div class="radio-row">
          <span class="label-text">3. Проверка при осмотре зубов </span>
          <span><input type="radio" name="teethObsv10" value="jjj">зубы осматривает судья</span>
          <div class="radio-group">
              <label><input type="radio" name="teethObsv1" value="kkk">без проблем</label>
              <label><input type="radio" name="teethObsv1" value="lll">с трудом</label>
              <label><input type="radio" name="teethObsv1" value="mmm">проявляет страх</label>
              <label><input type="radio" name="teethObsv1" value="nnn">невозможно осмотреть</label>
              <label><input type="radio" name="teethObsv1" value="ooo">не пытался</label>
          </div>
          <span><input type="radio" name="teethObsv20" value="ppp">зубы осматривает ведущий собак</span>
          <div class="radio-group">
              <label><input type="radio" name="teethObsv2" value="qqq">без проблем</label>
              <label><input type="radio" name="teethObsv2" value="rrr">с трудом</label>
              <label><input type="radio" name="teethObsv2" value="sss">проявляет страх</label>
              <label><input type="radio" name="teethObsv2" value="ttt">невозможно осмотреть</label>
              <label><input type="radio" name="teethObsv2" value="uuu">не пытался</label>
          </div>
        </div>

        <div class="radio-row">
          <span class="label-text">4. Проверка при показе</span>
          <div class="radio-group">
              <label><input type="radio" name="showtime" value="vvv">уверен в себе</label>
              <label><input type="radio" name="showtime" value="www">дружелюбен</label>
              <label><input type="radio" name="showtime" value="xxx">сдержан</label>
              <label><input type="radio" name="showtime" value="yyy">держится неуверенно</label>
              <label><input type="radio" name="showtime" value="zzz">проявляет агрессию</label>
          </div>
        </div>

        <div class="field">
          <label>Особые достоинства</label>
          <input type="text"  name="isthereanyspecificqualitieshere">
        </div>

        <div class="field">
          <label>Особые недостатки</label>
          <input type="text"  name="isthereanyspecificfaultshere">
        </div>

        <div class="field">
          <label>Рекомендации для племенного использования</label>
          <input type="text"  name="isthereanyrecomendstionshere">
        </div>
        
        <div class="actions">
          <%== linkTo("Вернуться на главную", urla("index")) %>
          <input type="submit" value="Отправить в Qt">
        </div>
      </form>
   </div>
</body>
</html>