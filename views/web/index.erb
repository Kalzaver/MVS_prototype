<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title><%= controller()->name() + ": " + controller()->activeAction() %></title>
  <style>
      body {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        margin: 0;
        padding: 20px;
        gap: 10px; /* отступы между колонками, при желании */
      }

      /* Контейнер с кнопками занимает колонки со 2 по 4 */
      .container {
        grid-column: 2 / 5; /* с линии 2 до линии 5 (колонки 2,3,4) */
        display: grid;
        grid-template-columns: repeat(3, 1fr); /* три внутренние колонки */
        gap: 10px; /* отступы между внутренними колонками */
        background: #f5f5f5; /* для наглядности, можно убрать */
        padding: 20px;
        border-radius: 8px;
      }

      /* Скрываем <br> внутри контейнера, чтобы они не ломали сетку */
      .container > br {
        display: none;
      }

      /* Все кнопки внутри контейнера */
      .container > button {
        /* Размещение по колонкам: нечётные – в первую внутреннюю (глобальная колонка 2),
          чётные – в третью внутреннюю (глобальная колонка 4) */
        grid-column: 1; /* значение по умолчанию для нечётных */
        white-space: normal;   /* разрешаем перенос текста */
        word-wrap: break-word; /* перенос длинных слов */
        padding: 12px 16px;
        border: none;
        background-color: #007bff;
        color: white;
        font-size: 16px;
        border-radius: 4px;
        cursor: pointer;
        transition: background-color 0.3s;
        width: 100%;          /* кнопка занимает всю ширину колонки */
        box-sizing: border-box;
      }

      /* Чётные кнопки помещаем в третью колонку */
      .container > button:nth-child(even) {
        grid-column: 3;
      }

      /* Стили для ссылок внутри кнопок (если linkTo генерирует <a>) */
      .container > button a {
        color: inherit;
        text-decoration: none;
        display: block;
        width: 100%;
        height: 100%;
      }

      /* Эффект при наведении */
      .container > button:hover {
        background-color: #0056b3;
      }

      .user-info {
        grid-column: 5 / 6;
        text-align: right;
        padding: 10px;
        background: #e9ecef;
        border-radius: 8px;
        font-size: 14px;
        margin-bottom: 10px;
      }
      
      .user-info p {
        grid-column: 1 / 6;
      }

  </style>
</head>
<body>

<h1>Главное меню</h1>
<p>Достпные к заполнению шаблоны документов РКФ</p>

<div class="user-info">
    <% tfetch(QString, username); %> <p><%= username %></p>
    <button type="button"><%== linkTo("Выйти", QUrl("http://localhost:8800/account/form")) %></button>
</div>

<div class="container">
  <button type="button"><%== linkTo("племенной смотр", urla("changePage")) %></button>
  <button type="button"><%== linkTo("отчёт главного судьи", urla("mainReport")) %></button>

  <button type="button"><%== linkTo("заявка на проведение племенного смотра", urla("ReqBreed")) %></button>
  <button type="button"><%== linkTo("заявка на присвоение титула", urla("ReqTitul")) %></button>

  <button type="button"><%== linkTo("реестр получения документов", urla("Reesrt")) %></button>
</div>

</body>
</html>